# ── Server ────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=production

# ── Database ──────────────────────────────────────────────────────────────
# Railway injects ${{MySQL.DATABASE_URL}} automatically when you link a MySQL
# service. Copy that variable reference in the Railway dashboard:
#   DB_URL=${{MySQL.DATABASE_URL}}
DB_URL=mysql://user:password@host:3306/railway

# ── Auth ──────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_64_char_random_hex
COOKIE_SECRET=replace_with_another_64_char_random_hex
JWT_EXPIRES_IN=7d

# ── AI ────────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash

# ── CORS ──────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins (Vercel / Netlify URL)
# Example: https://elibrary.vercel.app,https://elibrary.netlify.app
CLIENT_ORIGIN=https://your-frontend.vercel.app

# ── File storage ──────────────────────────────────────────────────────────
# On Railway, mount a persistent volume at /data/uploads via the Volumes tab.
# Set this to match the volume mount path.
UPLOAD_DIR=/data/uploads
MAX_FILE_SIZE_MB=20
